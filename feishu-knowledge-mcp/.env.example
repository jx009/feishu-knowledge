# 飞书知识库 MCP Server 环境变量配置
# 复制此文件为 .env 并填写真实值

# 运行环境与统一数据目录
APP_IMAGE=feishu-knowledge-mcp:latest
APP_ENV=production
APP_DATA_DIR=/app/runtime

# 飞书自建应用凭证
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_WIKI_SPACE_ID=your_wiki_space_id
# 支持 JSON 或 逗号分隔格式：分类1:node_x,分类2:node_y
FEISHU_CATEGORY_NODES={"最佳实践":"node_id_1","架构方案":"node_id_2"}

# OpenAI API 配置
OPENAI_API_KEY=your_openai_api_key
OPENAI_API_BASE=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Qdrant 向量数据库
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=knowledge_skills

# Dashboard
DASHBOARD_ENABLED=true
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
DASHBOARD_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/feishu_knowledge

# MCP 远程接入
MCP_TRANSPORT=streamable_http
MCP_HOST=0.0.0.0
MCP_PORT=8001
MCP_HTTP_PATH=/mcp
MCP_SSE_PATH=/mcp/sse
MCP_MESSAGE_PATH=/mcp/messages
MCP_PUBLIC_BASE_URL=

# 日志
LOG_LEVEL=INFO
LOG_FILE_ENABLED=true
LOG_DIR=logs
LOG_FILENAME=server.log

# 自动知识提取
EXTRACTION_ENABLED=true
EXTRACTION_MAX_CANDIDATES=5
EXTRACTION_MIN_SCORE=3
EXTRACTION_MIN_SEGMENT_LENGTH=120
EXTRACTION_MAX_EXCERPT_LENGTH=320
EXTRACTION_INCLUDE_FALLBACK=true

# 同步与删除策略
SYNC_MODE=repair_and_drift_detection
SYNC_MAX_RECORDS_PER_RUN=0
SYNC_CLEANUP_ORPHANS=true
COMPENSATION_BATCH_SIZE=100
COMPENSATION_INCLUDE_FAILED=true
COMPENSATION_INCLUDE_PENDING_DELETE=true
DELETION_STRATEGY=soft_delete_only
DELETION_UNMOUNT_FROM_WIKI=false
DELETION_ARCHIVE_PARENT_NODE=
